#!/usr/bin/env bash
# VOID-QRC Fase 1 — gate Hermiticidade (pre-commit)
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v python >/dev/null 2>&1 && ! command -v python3 >/dev/null 2>&1; then
  echo "[pre-commit] Python não encontrado — skip core tests"
  exit 0
fi

echo "[pre-commit] core/tests (Hermiticidade + Anderson)…"
bash "$ROOT/scripts/core-test.sh" -q --tb=line
